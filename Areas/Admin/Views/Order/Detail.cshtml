@model BookStore.Models.Order

@{
    ViewData["Title"] = $"Order #{Model.Id}";
}

<div class="container mt-4">
    <h2>Order #@Model.Id</h2>

    @if (TempData["success"] != null)
    {
        <div class="alert alert-success">@TempData["success"]</div>
    }
    @if (TempData["error"] != null)
    {
        <div class="alert alert-danger">@TempData["error"]</div>
    }

    <dl class="row">
        <dt class="col-sm-3">Customer</dt>
        <dd class="col-sm-9">@(Model.User?.Email ?? Model.UserId)</dd>

        <dt class="col-sm-3">Status</dt>
        <dd class="col-sm-9"><span class="badge bg-info">@Model.Status</span></dd>

        <dt class="col-sm-3">Total</dt>
        <dd class="col-sm-9">@Model.TotalAmount.ToString("N2")</dd>
    </dl>

    <h4 class="mt-4">Line items</h4>
    <table class="table table-bordered">
        <thead>
            <tr>
                <th>Book</th>
                <th>Price (snapshot)</th>
                <th>Qty</th>
                <th>Line total</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var line in Model.OrderDetails)
            {
                <tr>
                    <td>@(line.Book?.Title ?? "—")</td>
                    <td>@line.Price.ToString("N2")</td>
                    <td>@line.Quantity</td>
                    <td>@((line.Price * line.Quantity).ToString("N2"))</td>
                </tr>
            }
        </tbody>
    </table>

    <div class="card mt-4">
        <div class="card-body">
            <h5 class="card-title">Update status</h5>
            <form asp-area="Admin"
                  asp-controller="Order"
                  asp-action="UpdateStatus"
                  asp-route-id="@Model.Id"
                  method="post"
                  class="row g-2 align-items-end">
                @Html.AntiForgeryToken()
                <div class="col-auto">
                    <select name="status" class="form-select">
                        @foreach (var s in BookStore.Models.OrderStatuses.All)
                        {
                            <option value="@s" selected="@(Model.Status == s ? "selected" : null)">@s</option>
                        }
                    </select>
                </div>
                <div class="col-auto">
                    <button type="submit" class="btn btn-warning">Save status</button>
                </div>
            </form>
        </div>
    </div>

    <a asp-area="Admin"
       asp-controller="Order"
       asp-action="Index"
       class="btn btn-secondary mt-3">Back to list</a>
</div>