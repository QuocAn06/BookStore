@model IEnumerable<BookStore.Models.Book>

@{
    ViewData["Title"] = "Book List";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>Book List</h2>
        <a asp-area="Admin" asp-controller="Book" asp-action="Create" class="btn btn-primary">Create New</a>
    </div>

    @if (TempData["success"] != null)
    {
        <div class="alert alert-success">@TempData["success"]</div>
    }

    <table class="table table-bordered table-striped">
        <thead>
            <tr>
                <th style="width:70px;">Id</th>
                <th>Image</th>
                <th>Title</th>
                <th>Author</th>
                <th>Category</th>
                <th>Price</th>
                <th>Stock</th>
                <th style="width:220px;">Actions</th>
            </tr>
        </thead>
        <tbody>
            @if (Model.Any())
            {
                foreach (var item in Model)
                {
                    <tr>
                        <td>@item.Id</td>
                        <td>
                            @if (!string.IsNullOrEmpty(item.ImageUrl))
                            {
                                <img src="@item.ImageUrl" alt="Book Image" style="width:60px;height:80px;object-fit:cover;" />
                            }
                        </td>
                        <td>@item.Title</td>
                        <td>@item.Author</td>
                        <td>@item.Category?.Name</td>
                        <td>@item.Price.ToString("N2")</td>
                        <td>@item.Stock</td>
                        <td>
                            <a asp-area="Admin" asp-controller="Book" asp-action="Edit" asp-route-id="@item.Id" class="btn btn-warning btn-sm">Edit</a>
                            <a asp-area="Admin" asp-controller="Book" asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger btn-sm">Delete</a>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="8" class="text-center">No books found.</td>
                </tr>
            }
        </tbody>
    </table>
</div>