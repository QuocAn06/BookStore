@model BookStore.Models.Book

@{
    ViewData["Title"] = "Delete Book";
}

<div class="container mt-4">
    <h2>Delete Book</h2>
    <hr />

    <div class="alert alert-warning">
        Are you sure you want to delete this book?
    </div>

    <dl class="row">
        <dt class="col-sm-2">Title</dt>
        <dd class="col-sm-10">@Model.Title</dd>

        <dt class="col-sm-2">Author</dt>
        <dd class="col-sm-10">@Model.Author</dd>

        <dt class="col-sm-2">Category</dt>
        <dd class="col-sm-10">@Model.Category?.Name</dd>

        <dt class="col-sm-2">Image</dt>
        <dd class="col-sm-10">
            @if (!string.IsNullOrEmpty(Model.ImageUrl))
            {
                <img src="@Model.ImageUrl" alt="Book Image" style="width:100px;height:130px;object-fit:cover;" />
            }
            else
            {
                <span class="text-muted">No image</span>
            }
        </dd>
    </dl>

    <form asp-area="Admin" asp-controller="Book" asp-action="Delete" method="post">
        <input asp-for="Id" type="hidden" />
        <button type="submit" class="btn btn-danger">Delete</button>
        <a asp-area="Admin" asp-controller="Book" asp-action="Index" class="btn btn-secondary">Back to List</a>
    </form>
</div>