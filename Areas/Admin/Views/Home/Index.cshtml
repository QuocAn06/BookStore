@model AdminHomeBooksVM

@{
    ViewData["Title"] = "Admin Home";
    var prevPage = Model.CurrentPage - 1;
    var nextPage = Model.CurrentPage + 1;
}

<div class="container mt-4">

    <div class="row g-3 mb-4">
        <div class="col-md-6">
            <div class="card border-primary h-100">
                <div class="card-body">
                    <h5 class="card-title text-muted">Tổng đơn hàng</h5>
                    <p class="display-6 mb-0">@Model.TotalOrders</p>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card border-success h-100">
                <div class="card-body">
                    <h5 class="card-title text-muted">Tổng doanh thu</h5>
                    <p class="display-6 mb-0">@Model.TotalRevenue.ToString("N0") ₫</p>
                </div>
            </div>
        </div>
    </div>

    <h1 class="mb-3">Admin Dashboard</h1>
    <p class="text-muted mb-4">Tổng quan và danh sách sách gần đây.</p>

    <table class="table table-bordered table-striped">
        <thead>
            <tr>
                <th style="width:70px;">Id</th>
                <th>Title</th>
                <th>Author</th>
                <th>Category</th>
                <th>Price</th>
                <th>Stock</th>
            </tr>
        </thead>
        <tbody>
            @if (Model.Books.Count > 0)
            {
                foreach (var item in Model.Books)
                {
                    <tr>
                        <td>@item.Id</td>
                        <td>@item.Title</td>
                        <td>@item.Author</td>
                        <td>@(item.Category?.Name ?? "—")</td>
                        <td>@item.Price.ToString("N2")</td>
                        <td>@item.Stock</td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="6" class="text-center">No books found.</td>
                </tr>
            }
        </tbody>
    </table>

    @if (Model.TotalPages > 1)
    {
        <nav aria-label="Book pagination" class="mt-3">
            <ul class="pagination">
                <li class="page-item @(Model.HasPreviousPage ? "" : "disabled")">
                    <a class="page-link"
                       asp-area="Admin"
                       asp-controller="Home"
                       asp-action="Index"
                       asp-route-page="@prevPage">Previous</a>
                </li>
                <li class="page-item disabled">
                    <span class="page-link">Page @Model.CurrentPage of @Model.TotalPages</span>
                </li>
                <li class="page-item @(Model.HasNextPage ? "" : "disabled")">
                    <a class="page-link"
                       asp-area="Admin"
                       asp-controller="Home"
                       asp-action="Index"
                       asp-route-page="@nextPage">Next</a>
                </li>
            </ul>
        </nav>
    }
</div>